{
  "name": "jammincms",
  "version": "0.1.1",
  "description": "Local bridge server for Jammin CMS Chrome extension - connects to Claude Code CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jammincms": "./dist/index.js"
  },
  "files": [
    "dist",
    "extension"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "copy-extension": "rm -rf extension && cp -r ../extension/dist extension",
    "prepublishOnly": "npm run build && npm run copy-extension"
  },
  "keywords": [
    "cms",
    "claude",
    "claude-code",
    "inline-editing",
    "chrome-extension",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
